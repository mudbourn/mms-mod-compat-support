{
  "schemaVersion": 1,
  "id": "mms_compat",
  "version": "${version}",
  "name": "MMS Mod Compat Support",
  "description": "Server-wide mod compat patches for MMSLive01. Creative-tab dedup, REI null-filter fix, CA+Trinkets bridge, AR item-drop suppression, creative embargo, vanity armor, Jobs+ lang fix, ModMetro seating + localization.",
  "environment": "*",
  "entrypoints": {
    "main": ["info.mudbourn.mmscompat.MmsModCompatSupport"]
  },
  "mixins": ["mms_compat.mixins.json", "mms_compat.rei.mixins.json", "mms_compat.rubies.mixins.json", "mms_compat.ca.mixins.json", "mms_compat.ar.mixins.json", "mms_compat.jeg.mixins.json", "mms_compat.furnish.mixins.json", "mms_compat.jobsplus.mixins.json", "mms_compat.metro.mixins.json", "mms_compat.metrofix.mixins.json", "mms_compat.xaero.mixins.json"],
  "depends": {
    "fabricloader": ">=0.16.0",
    "minecraft": "~1.21.11",
    "java": ">=21",
    "fabric-api": "*"
  }
}
